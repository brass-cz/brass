fun arr_i32() -> int64 {
    let a = [3, 1, 4, 1, 5, 9, 2, 6]
    return a.filter((x) -> x > 2).map((x) -> x * 3).fold(0, (s, x) -> s + x)
}

fun arr_i64() -> int64 {
    let a: int64[] = [30000000000, 1, 4, 1, 5]
    return a.fold(0, (s, x) -> s + x) % 1000000007
}

fun arr_f64() -> int64 {
    let a = [1.5, 2.5, 3.5, 4.5]
    let s = a.map((x) -> x * 2.0).fold(0.0, (t, x) -> t + x)
    return if s > 20.0 { 1 } else { 0 }
}


