// Concurrency: four spawned tasks each run a private compute loop and fold
// their result into a shared accumulator once. Exercises the spawn-reachable
// precompile analysis on the lazy path (spawned bodies must be ready before
// the tasks run) against eager's compile-everything-first.

type Acc = {
    total: int64
}

fun Acc.add(self, n: int64) {
    self.total += n
}

fun mix(x: int64) -> int64 {
    return (x * 48271) % 2147483647
}

fun worker_sum(seed: int64, iters: int64) -> int64 {
    let x = seed
    let acc: int64 = 0
    let i: int64 = 0
    while i < iters {
        x = mix(x)
        acc = (acc + x) % 1000000007
        i += 1
    }
    return acc
}

fun main() {
    println("begin")
    let acc = Acc { total: 0 }
    spawn(() -> {
        acc.add(worker_sum(1, 8000000))
    })
    spawn(() -> {
        acc.add(worker_sum(2, 8000000))
    })
    spawn(() -> {
        acc.add(worker_sum(3, 8000000))
    })
    spawn(() -> {
        acc.add(worker_sum(4, 8000000))
    })
    sync()
    with(acc, (a) -> {
        println("total = {a.total}")
    })
}
